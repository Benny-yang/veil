# ── 環境識別 ──────────────────────────────
APP_ENV=development
APP_PORT=8080

# ── 資料庫 (MySQL) ─────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=veil_dev

# ── JWT ───────────────────────────────────
JWT_SECRET=your-strong-random-secret
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# ── Email (Resend) ─────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@veil.tw

# ── 媒體上傳 (GCP Storage) ────────────────
GCS_BUCKET_NAME=veil-dev-media
GCS_PROJECT_ID=your_gcp_project_id

# ── CORS ──────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── 信用分數設定 ───────────────────────────
CREDIT_SCORE_INIT=60
CREDIT_SCORE_MAX=100

# ── 交易超時天數（JSON 格式）───────────────
TX_TIMEOUT_DAYS={"pending":3,"shipping":10,"received":7}

# ── Zone 月度操作限制（未驗證帳號）──────────
ZONE_CREATE_LIMIT=5
ZONE_APPLY_LIMIT=10
